{
  "name": "splash/framework",
  "type": "library",
  "description": "Write easily your USSD based applications.",
  "keywords": [
    "ussd",
    "whatsapp"
  ],
  "homepage": "https://github.com/vansbeck07/framework",
  "license": "MIT",
  "authors": [
    {
      "name": "Evans Owusu Ofori",
      "email": "vansbeck07@gmail.com",
      "role": "Maintainer",
      "homepage": "https://github.com/vansbeck07"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "^8.3",
    "vansbeck07/dotenv": "^0.4",
    "vansbeck07/notify": "^0.0",
    "vansbeck07/phputils": "^0.0",
    "vansbeck07/dir-dot-config": "^0.0",
    "vansbeck07/string-utils": "^0.0",
    "vansbeck07/array-utils": "^0.0",
    "vansbeck07/os-utils": "^0.0",
    "psy/psysh": "^0.12",
    "illuminate/database": "^10.0 || ^11.0",
    "symfony/console": "^7.0",
    "symfony/finder": "^7.0",
    "peppeocchi/php-cron-scheduler": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0",
    "nunomaduro/collision": "^7.0 || ^8.0"
  },
  "config": {
    "optimize-autoloader": true
  },
  "autoload": {
    "files": [
      "src/Support/helpers.php"
    ],
    "psr-4": {
      "Splash\\": "src/"
    }
  }
}
